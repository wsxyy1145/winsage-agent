# WinSage 环境变量配置示例
# 复制此文件为 .env 并填入你的实际配置

# OpenAI 配置
WINSAGE_MODELS_OPENAI_API_KEY=sk-your-openai-api-key
WINSAGE_MODELS_OPENAI_BASE_URL=https://api.openai.com/v1
WINSAGE_MODELS_OPENAI_DEFAULT_MODEL=gpt-4

# Anthropic 配置
WINSAGE_MODELS_ANTHROPIC_API_KEY=your-anthropic-api-key
WINSAGE_MODELS_ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
WINSAGE_MODELS_ANTHROPIC_DEFAULT_MODEL=claude-3-opus-20240229

# Azure OpenAI 配置
WINSAGE_MODELS_AZURE_API_KEY=your-azure-api-key
WINSAGE_MODELS_AZURE_ENDPOINT=https://your-resource.openai.azure.com/
WINSAGE_MODELS_AZURE_DEPLOYMENT=gpt-4
WINSAGE_MODELS_AZURE_API_VERSION=2024-02-15-preview

# Ollama 配置
WINSAGE_MODELS_OLLAMA_BASE_URL=http://localhost:11434
WINSAGE_MODELS_OLLAMA_MODEL=llama2

# 记忆系统配置
WINSAGE_MEMORY_DATABASE_URL=postgresql://postgres:postgres@localhost/winsage
WINSAGE_MEMORY_ENABLE_VECTOR_SEARCH=false
WINSAGE_MEMORY_MAX_HISTORY_LENGTH=100

# 沙箱配置
WINSAGE_SANDBOX_ENABLED=true
WINSAGE_SANDBOX_AUTO_CLEANUP=true
WINSAGE_SANDBOX_TIMEOUT_SECONDS=300

# 通用配置
WINSAGE_GENERAL_DEFAULT_MODEL=gpt-4
WINSAGE_GENERAL_TEMPERATURE=0.7
WINSAGE_GENERAL_MAX_TOKENS=4096
WINSAGE_GENERAL_STREAMING=true

# 日志级别 (debug, info, warn, error)
RUST_LOG=info
